        "def calculate_student_performance():\n",
        "    print(\"🎓 Welcome to the AI Student Performance & Grade Predictor! 🚀\\n\")\n",
        "\n",
        "    try:\n",
        "        # 📥 Capturing User Inputs with Validation\n",
        "        hours_studied = float(input(\"Enter hours studied per day: \"))\n",
        "        attendance = float(input(\"Enter attendance percentage (0-100): \"))\n",
        "        prev_marks = float(input(\"Enter previous exam marks percentage (0-100): \"))\n",
        "        sleep_hours = float(input(\"Enter sleep hours per night: \"))\n",
        "        screen_time = float(input(\"Enter daily screen time (hours): \"))\n",
        "\n",
        "        # 🛡️ Input Validation Checks\n",
        "        if not (0 <= attendance <= 100 and 0 <= prev_marks <= 100):\n",
        "            print(\"❌ Error: Attendance and Previous Marks must be between 0 and 100!\")\n",
        "            return\n",
        "\n",
        "        # 🧮 Mathematical Formula for Predicted Percentage\n",
        "        study_score = min(hours_studied * 8, 40)          # Max 40 points from study hours\n",
        "        attendance_score = (attendance / 100) * 20       # Max 20 points from attendance\n",
        "        base_marks_score = (prev_marks / 100) * 30       # Max 30 points from past performance\n",
        "\n",
        "        # Lifestyle adjustments (Sleep & Screen Time)\n",
        "        lifestyle_bonus = 10 if (7 <= sleep_hours <= 9) else 2\n",
        "        screen_penalty = max(0, (screen_time - 3) * 2)   # Penalty if screen time exceeds 3 hours\n",
        "\n",
        "        predicted_percentage = study_score + attendance_score + base_marks_score + lifestyle_bonus - screen_penalty\n",
        "        predicted_percentage = max(0, min(float(predicted_percentage), 100.0)) # Clamp between 0 and 100\n",
        "\n",
        "        # 📊 Grade Determination (Conditionals)\n",
        "        if predicted_percentage >= 90:\n",
        "            grade = \"A+\"\n",
        "        elif predicted_percentage >= 80:\n",
        "            grade = \"A\"\n",
        "        elif predicted_percentage >= 70:\n",
        "            grade = \"B+\"\n",
        "        elif predicted_percentage >= 60:\n",
        "            grade = \"B\"\n",
        "        elif predicted_percentage >= 50:\n",
        "            grade = \"C\"\n",
        "        else:\n",
        "            grade = \"F (Needs Improvement)\"\n",
        "\n",
        "        # 🔥 Probability of Scoring Above 90%\n",
        "        if predicted_percentage >= 85:\n",
        "            prob_above_90 = \"High (~85%)\"\n",
        "        elif predicted_percentage >= 75:\n",
        "            prob_above_90 = \"Moderate (~50%)\"\n",
        "        else:\n",
        "            prob_above_90 = \"Low (<20%)\"\n",
        "\n",
        "        # 💡 Personalized Suggestions Generation (Conditionals)\n",
        "        suggestions = []\n",
        "        if hours_studied < 3:\n",
        "            suggestions.append(\"📈 Try increasing your daily study hours by at least 1-2 hours.\")\n",
        "        if attendance < 85:\n",
        "            suggestions.append(\"🏫 Improving your class attendance will directly boost your academic consistency.\")\n",
        "        if sleep_hours < 7:\n",
        "            suggestions.append(\"😴 Aim for 7-9 hours of sleep to optimize memory retention and focus.\")\n",
        "        if screen_time > 4:\n",
        "            suggestions.append(\"📱 Cutting down non-academic screen time can significantly improve concentration.\")\n",
        "        if not suggestions:\n",
        "            suggestions.append(\"🌟 Excellent daily habits! Maintain this balanced lifestyle.\")\n",
        "\n",
        "        # 📋 Display Final Output Report\n",
        "        print(\"\\n\" + \"=\"*50)\n",
        "        print(\"📊 STUDENT PERFORMANCE PREDICTION REPORT 📊\")\n",
        "        print(\"=\"*50)\n",
        "        print(f\"🎯 Predicted Exam Percentage: {predicted_percentage:.2f}%\")\n",
        "        print(f\"🏆 Estimated Grade: {grade}\")\n",
        "        print(f\"🔥 Probability of Scoring >90%: {prob_above_90}\")\n",
        "        print(\"\\n💡 Personalized Suggestions:\")\n",
        "        for suggestion in suggestions:\n",
        "            print(f\" - {suggestion}\")\n",
        "        print(\"=\"*50)\n",
        "        print(\"✅ Analysis Complete! Ready to push to GitHub & LinkedIn. 🚀\")\n",
        "\n",
        "    except ValueError:\n",
        "        print(\"❌ Invalid input! Please enter numbers only for your statistics.\")\n",
        "\n",
        "# Run the program function\n",
        "calculate_student_performance()"
